# APP_URL — URL หลักของแอป (ควรตรงกับ NEXTAUTH_URL ในแต่ละสภาพแวดล้อม)
APP_URL="http://localhost:3000"

# Google Service Account (JSON ที่ root — เช่น Credentials.json จาก Google Cloud)
GOOGLE_SERVICE_ACCOUNT_FILE="Credentials.json"
# Parent folder (optional fallback)
GOOGLE_DRIVE_FOLDER_ID="YOUR_PARENT_DRIVE_FOLDER_ID"
# Subfolder IDs (recommended)
GOOGLE_DRIVE_IMAGE_FOLDER_ID="YOUR_IMAGE_SUBFOLDER_ID"
GOOGLE_DRIVE_JSON_FOLDER_ID="YOUR_JSON_SUBFOLDER_ID"
# User KYC folder (recommended): เก็บบัตรประชาชน/สมุดบัญชีของผู้ใช้ (แยกสิทธิ์จากรูปแคมเปญ/อื่นๆ)
GOOGLE_DRIVE_USER_KYC_FOLDER_ID="YOUR_USER_KYC_FOLDER_ID"

# --- CMS Admin (JWT + HttpOnly cookie; ชื่อผู้ใช้/รหัสผ่านใน MongoDB — รัน npm run seed:cms-admin; ค่าเริ่มต้น admin1234 / admin1234 หรือตั้ง SEED_ADMIN_USERNAME / SEED_ADMIN_PASSWORD) ---
# รัน npm run generate:jwt-secrets แล้ววางค่า (อย่างน้อย 32 ตัวอักษร)
ADMIN_JWT_SECRET=""
# ถ้าไม่ตั้งค่า ADMIN_JWT_EXPIRES ระบบจะหมดอายุทุกวันเวลา 00:00 น. ตามเวลาไทย
# ADMIN_JWT_EXPIRES="8h"
# Signs flexshare_user_token (API + /api/auth/me). User routes: middleware checks session via /api/auth/me on Node, not Edge JWT verify.
USER_JWT_SECRET=""
# USER_JWT_EXPIRES="3d"

# พอร์ทัลสปอนเซอร์ (จัดการโฆษณา — ไอดี/รหัสผ่าน แยกจาก LINE)
# SPONSOR_JWT_SECRET=""
# SPONSOR_JWT_EXPIRES="8h"

#URI TO START APP USER&ADMIN
URI_USER="http://localhost:3000/user"
URI_ADMIN="http://localhost:3000/cms/dashboard"

# MongoDB (API routes / seed)
MONGODB_URI="mongodb://localhost:27017/flexshare"
# ชื่อฐานข้อมูลจริง (ค่าเริ่มต้น flexshare) — ใช้เมื่อ Atlas URI ลงท้ายแค่ /? ไม่มีชื่อ db ไม่งั้นข้อมูลไปโผล่ที่ test
# MONGODB_DB_NAME="flexshare"
# Optional: บน Windows ถ้า mongodb+srv ขึ้น querySrv ECONNREFUSED โค้ดจะใช้ 8.8.8.8 / 1.1.1.1 อัตโนมัติ — ปิดด้วย MONGODB_DISABLE_DNS_FIX=1 หรือกำหนด DNS เอง:
# MONGODB_DNS_SERVERS="8.8.8.8,1.1.1.1"
# MONGODB_DISABLE_DNS_FIX="1"
# Optional fallback (แนะนำสำหรับเครือข่ายที่บล็อก DNS SRV): ใส่ Atlas "Standard connection string" แบบ mongodb://...
# MONGODB_URI_DIRECT="mongodb://user:pass@host1:27017,host2:27017,host3:27017/flexshare?replicaSet=...&ssl=true&authSource=admin"

# =============================================================================
# LINE Login (Custom OAuth) — ผู้ใช้และแอดมินใช้ LINE Login channel เดียวกัน
# JWT แยก: USER_JWT_SECRET = session ผู้ใช้แอป | ADMIN_JWT_SECRET = session CMS + state เชื่อม LINE แอดมิน
# -----------------------------------------------------------------------------
# NEXTAUTH_SECRET      : สตริงสุ่มยาว (ยังใช้เป็น secret ภายในระบบ)
# NEXTAUTH_URL         : URL หลักของแอป — dev: http://localhost:3000 | prod: https://โดเมน
# APP_URL             : ควรตรงกับ NEXTAUTH_URL และต้องเป็น base domain เท่านั้น
# LINE_CLIENT_ID       : LINE Developers → Channel (LINE Login) → Channel ID
# LINE_CLIENT_SECRET   : Channel secret ของช่อง LINE Login เดียวกัน
# Callback ใน LINE:   {APP_URL}/api/auth/line/callback
# อย่าแจกลิงก์ /api/auth/signin/line (NextAuth) — middleware ส่งไป /api/auth/line แล้ว; redirect_uri ของ NextAuth คือ …/callback/line ซึ่งไม่ตรง callback ด้านบน
# ห้ามตั้ง APP_URL / NEXTAUTH_URL เป็น https://domain.com/user หรือ path อื่นที่มี suffix
# =============================================================================
NEXTAUTH_URL="http://localhost:3000"
# Also used to sign LINE Login OAuth `state` (custom /api/auth/line) when cookies are dropped by in-app browsers.
NEXTAUTH_SECRET=""
LINE_CLIENT_ID=""
LINE_CLIENT_SECRET=""

# =============================================================================
# LINE Messaging API / LINE OA Notifications
# -----------------------------------------------------------------------------
# ใช้ LINE Login ชุดเดิมต่อได้ตามปกติ แต่การ "แจ้งเตือนเข้า LINE @" ต้องมี Channel
# ของ Messaging API เพิ่มสำหรับ OA ที่จะส่งข้อความ
#
# ถ้าต้องการแยก @ ระหว่างผู้ใช้และแอดมิน:
# - LINE_USER_NOTIFY_*  = OA สำหรับผู้ใช้
# - LINE_ADMIN_NOTIFY_* = OA สำหรับแอดมิน
#
# ถ้าใช้ OA ตัวเดียว สามารถใส่ token/secret ชุดเดียวกันทั้งสองฝั่งได้
# ผู้ใช้ต้องเป็นเพื่อนกับ OA ผู้ใช้
# แอดมินต้องเป็นเพื่อนกับ OA แอดมิน และระบุ userId ใน DB หรือ LINE_ADMIN_NOTIFY_USER_IDS
# =============================================================================
LINE_USER_NOTIFY_ENABLED="0"
LINE_USER_NOTIFY_CHANNEL_ACCESS_TOKEN=""
LINE_USER_NOTIFY_CHANNEL_SECRET=""

LINE_ADMIN_NOTIFY_ENABLED="0"
LINE_ADMIN_NOTIFY_CHANNEL_ACCESS_TOKEN=""
LINE_ADMIN_NOTIFY_CHANNEL_SECRET=""
# comma-separated LINE userIds สำหรับแอดมินที่ต้องการรับแจ้งเตือน เช่น U123,U456
LINE_ADMIN_NOTIFY_USER_IDS=""

# =============================================================================
# LIFF — แอปใน LINE / หน้าแชร์ (โค้ดอ่านจาก NEXT_PUBLIC_LIFF_ID หรือ LIFF_ID)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_LIFF_ID  : LIFF ID — LINE Developers → LIFF (ต้องมีเพื่อปุ่มแชร์ในแอป)
# LIFF_ID              : ทางเลือกสำหรับ /api/liff/config ถ้าไม่ตั้ง NEXT_PUBLIC_LIFF_ID
#
# Endpoint URL (LINE Console) กับลิงก์แชร์ (lib/liffShare.ts) ต้องสอดคล้องกัน:
#
# A) Endpoint = https://yourdomain.com (ราก)
#    → ตั้ง NEXT_PUBLIC_LIFF_ENDPOINT_INCLUDES_SHARE=0 หรือไม่ตั้ง
#    → ลิงก์แชร์: https://liff.line.me/<LIFF_ID>/share/<campaignId>?id=1
#    → Next route: /share/[campaignId]
#
# B) Endpoint = https://yourdomain.com/share (ลงท้าย /share แล้ว — แบบโปรเจกต์ line_flex_tem)
#    → ตั้ง NEXT_PUBLIC_LIFF_ENDPOINT_INCLUDES_SHARE=1
#    → ลิงก์แชร์: https://liff.line.me/<LIFF_ID>/<campaignId>?id=1
#    → Next ยังเปิดที่ /share/[campaignId] เหมือนเดิม
#
# เปิด Share Target Picker: LIFF → Edit → Share messages → Share target
#
# ถ้า Endpoint เป็น https://domain.com/user ให้ตั้ง path ให้ตรง route จริง เช่น:
# NEXT_PUBLIC_LIFF_APP_PATH=user/share (ใช้คู่กับ ENDPOINT_INCLUDES_SHARE=0)
# =============================================================================
NEXT_PUBLIC_LIFF_ID=""
# NEXT_PUBLIC_LIFF_ENDPOINT_INCLUDES_SHARE=0
# NEXT_PUBLIC_LIFF_APP_PATH=share
# LIFF_ID=""